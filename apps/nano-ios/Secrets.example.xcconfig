// Copy this file to `Secrets.xcconfig` (gitignored) and fill in the client id(s) you want to enable.
// Each provider is independent — fill in only the one(s) you use. After editing, run `xcodegen generate`.
// There is NO client secret for either — PKCE handles the exchange.
//
// Google Drive (docs/google-drive-setup.md). Both values come from the ONE client id:
//   client id  = 1234567890-abcdef.apps.googleusercontent.com
//   reversed   = com.googleusercontent.apps.1234567890-abcdef   (drop ".apps.googleusercontent.com",
//                                                                 prepend "com.googleusercontent.apps.")
//
// OneDrive (docs/onedrive-setup.md). Only the client id is needed — the redirect scheme defaults to
// msauth.<bundle-id> in Config.xcconfig (override here only if your bundle id differs):
//   client id  = 00000000-0000-0000-0000-000000000000   (the Entra "Application (client) ID")

GOOGLE_OAUTH_CLIENT_ID = YOUR_GOOGLE_IOS_CLIENT_ID
GOOGLE_OAUTH_REVERSED_SCHEME = com.googleusercontent.apps.YOUR_GOOGLE_IOS_CLIENT_ID

MICROSOFT_OAUTH_CLIENT_ID = YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_OAUTH_REDIRECT_SCHEME = msauth.com.willeasp.nanometers.ios
